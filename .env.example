# Copy this file to .env and fill in your values for local development.
# The .env file is NOT committed to git (it's in .gitignore).
# In Cloud Run, set these as environment variables via set-env-vars.sh.

# ── GCP ───────────────────────────────────────────────────────────────────────
# Required — get this from the GCP Console after creating your project.
CLOUD_PROJECT_ID=your-gcp-project-id

# ── PCP credentials (stored in GCP Secret Manager — NOT here) ─────────────────
# Create a Personal Access Token at: https://api.planningcenteronline.com/oauth/applications
# Then store the values in GCP Secret Manager:
#   gcloud secrets create PCP_APP_ID --data-file=-   (then paste the app ID)
#   gcloud secrets create PCP_SECRET --data-file=-   (then paste the secret)
# The app fetches them automatically at runtime using CLOUD_PROJECT_ID above.

# ── CC credentials (stored in GCP Secret Manager — NOT here) ──────────────────
# Create an app at: https://developer.constantcontact.com/
# Store the access token in GCP Secret Manager:
#   gcloud secrets create CC_ACCESS_TOKEN --data-file=-
# The app fetches it automatically at runtime.

# ── PCP field definition IDs ──────────────────────────────────────────────────
# Each custom field in PCP has a numeric ID. Find it by:
#   1. Set LOG_PAYLOADS=true below and submit a test person with the field filled in.
#   2. Look in the server logs for type=FieldDatum → relationships.field_definition.data.id
PCP_NEWSLETTER_FIELD_ID=your-pcp-field-definition-id

# ── Constant Contact list IDs ─────────────────────────────────────────────────
# Find list UUIDs in CC: Contacts → Lists → click a list → UUID is in the URL.
CC_NEWSLETTER_LIST_ID=your-cc-list-uuid

# ── Feature flags ─────────────────────────────────────────────────────────────
# TEST_MODE=true skips the CC API call and logs what would happen instead.
# Set to false only when you're ready to go live.
TEST_MODE=true

# LOG_PAYLOADS=true logs the raw webhook payload and PCP API responses.
# Useful for discovering field definition IDs. Contains PII — disable when stable.
LOG_PAYLOADS=true
